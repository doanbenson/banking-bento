{
  "name": "plaid-bank-app",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "localstack:up": "docker compose up -d localstack",
    "localstack:down": "docker compose down",
    "ssm:seed": "node scripts/seed-ssm-local.mjs",
    "web:env:api": "node scripts/sync-api-gateway-env.mjs",
    "backend:bootstrap:local": "npm run bootstrap:local --workspace=serverless-backend",
    "backend:deploy:local": "npm run deploy:local --workspace=serverless-backend",
    "build": "npm run build --workspace=web",
    "start": "npm run start --workspace=web",
    "lint": "npm run lint --workspace=web",
    "deploy:local": "npm run deploy:local --workspace=serverless-backend"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@aws-sdk/client-ssm": "^3.907.0"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1038.0"
  }
}
